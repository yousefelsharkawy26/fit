# FitOS Environment Configuration
# Copy this file to .env and fill in your real credentials.

# --- Google Gemini API ---
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=AIza_YOUR_GEMINI_API_KEY_HERE

# --- Supabase (Global Flywheel) ---
# Needed for Module F synchronization.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# --- App Settings ---
# Set to 'true' to use the real Supabase client instead of the mock one.
USE_SUPABASE_FLYWHEEL=false
